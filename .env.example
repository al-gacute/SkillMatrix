# Environment variables for Docker deployment
# Copy this file to .env and fill in your values

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/skillmatrix
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your-secure-password-here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Application Configuration
NODE_ENV=production
PORT=5000
CLIENT_URL=http://localhost:3000

# Default admin bootstrap accounts
# These are created automatically on startup if they do not already exist.
DEFAULT_ADMIN_EMAIL=admin@skillmatrix.com
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Administrator
DEFAULT_SUPERADMIN_EMAIL=superadmin@skillmatrix.com
DEFAULT_SUPERADMIN_PASSWORD=Super@123
DEFAULT_SUPERADMIN_FIRST_NAME=Super
DEFAULT_SUPERADMIN_LAST_NAME=Admin
